# Rust
/target/
**/target/
**/*.rs.bk
Cargo.lock

# Node
node_modules/
dist/
.vite/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
**/.DS_Store
.AppleDouble
.LSOverride

# Build artifacts
artifacts/
*.dylib
*.so
*.dll
*.a

# Debug
*.dSYM/
*.log

# Profiling
cargo-flamegraph.trace/
flamegraph.svg
perf.data*

# Temporary
*.tmp
*.temp

# Stray test binaries — never let an unintended Mach-O / ELF slip into
# the repo via `git add .`. Real test runners are cargo test / flutter
# test, not standalone harnesses checked into the tree.
test_send

# Nested Flutter / Xcode build pyramids. flutter_ui/.gitignore only
# covers `/build/` relative to its own dir, which leaves
# `flutter_ui/macos/build/` (Xcode DerivedData mirror) untracked-but-
# noisy in `git status`. `**/build/` from root catches every nested
# build dir under flutter_ui/* without touching crates/*/target (which
# is already covered by /target above).
**/build/

# Environment
.env
.env.local
._*

# IntelliJ / Android Studio
*.iml

# Backup files
*.bak

# Generated Flutter files (flutter gen-l10n output)
flutter_ui/lib/l10n/app_localizations*.dart

# Generated FFI bridge (flutter_rust_bridge codegen)
flutter_ui/lib/src/rust/bridge_generated.dart

# Legacy reference (old project name)
ReelToReel-ReverseEngineered-ULTIMATE.txt
